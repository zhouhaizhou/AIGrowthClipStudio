DB_PATH=./data/agcs.db
STORAGE_DIR=./storage
API_PORT=8787
WORKER_POLL_INTERVAL_MS=1000
ASR_PROVIDER=mock
# HIGHLIGHT_PROVIDER / PACKAGING_PROVIDER: mock | llm (Anthropic SDK, 需 ANTHROPIC_API_KEY)
#   | claude-cli (走本机 `claude` CLI / Claude Code 订阅，无需 API key)
HIGHLIGHT_PROVIDER=mock
PACKAGING_PROVIDER=mock
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=
LLM_MODEL=claude-sonnet-4-6
